@startuml Inbound_Message_Sequence_Diagram
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Inbound Telegram Message — AI Sales Manager Sequence Diagram

actor "Lead" as Lead
participant "Telegram\nMTProto API" as MTProto <<external>>
participant "SellerClient" as SellerClient <<app.bots.seller_client>>
participant "InboundListener" as Inbound <<app.bots.inbound_listener>>
database "PostgreSQL" as DB
participant "ConversationService" as ConvSvc <<app.services.conversation_service>>
participant "LLMEngine" as LLM <<app.llm.engine>>
participant "IntentClassifier" as Intent <<app.llm.intent_classifier>>
participant "Prompts" as Prompts <<app.llm.prompts>>
participant "Funnel" as Funnel <<app.core.funnel>>
participant "StateMachine" as StateMachine <<app.core.state_machine>>
participant "Humanizer" as Humanizer <<app.core.humanizer>>
database "Redis" as Redis
participant "NotificationService" as Notif <<app.services.notification_service>>
participant "AdminBot" as AdminBot <<app.bots.admin_bot>>
participant "Telegram\nBot API" as BotAPI <<external>>

autonumber

Lead -> MTProto : send text message
MTProto -> SellerClient : incoming message
SellerClient -> Inbound : on_message handler

activate Inbound

Inbound -> DB : find/create Contact
DB --> Inbound : Contact

Inbound -> DB : find/create Conversation
DB --> Inbound : Conversation

Inbound -> ConvSvc : add_message(inbound)
activate ConvSvc
ConvSvc -> DB : insert Message, update timestamp
DB --> ConvSvc : Message
ConvSvc -> Redis : invalidate conversation cache
ConvSvc --> Inbound : Message

deactivate ConvSvc

Inbound -> DB : update CampaignContact status replied

Inbound -> SellerClient : read_history(user_id)
SellerClient -> MTProto : mark messages read

Inbound -> ConvSvc : extract_facts_from_message(text)
activate ConvSvc
ConvSvc -> LLM : generate_with_fallback(fact extraction prompt)
LLM -> MTProto : -- (over HTTPS)
MTProto --> LLM : raw facts JSON
LLM --> ConvSvc : extracted facts
ConvSvc --> Inbound : facts

deactivate ConvSvc

alt facts extracted
    Inbound -> ConvSvc : update_lead_facts(conversation_id, facts)
    activate ConvSvc
    ConvSvc -> DB : merge facts into Conversation
    ConvSvc -> Redis : invalidate cache
    deactivate ConvSvc
end

Inbound -> Intent : classify_intent(text, engine)
activate Intent
Intent -> LLM : generate_with_fallback(classification prompt)
LLM -> MTProto : -- (over HTTPS)
MTProto --> LLM : intent label
LLM --> Intent : raw text
Intent --> Inbound : intent (e.g. positive, meeting_intent)

deactivate Intent

Inbound -> Funnel : next_stage(script, current_stage, intent)
Funnel --> Inbound : new conversation_stage

Inbound -> ConvSvc : get_conversation_context(limit=10)
activate ConvSvc
ConvSvc -> Redis : get cached context
alt cache miss
    ConvSvc -> DB : load Messages + Conversation facts
    DB --> ConvSvc : messages & facts
    ConvSvc -> Redis : cache context
end
ConvSvc --> Inbound : context {messages, facts}

deactivate ConvSvc

Inbound -> Prompts : build_system_prompt(script, stage)
Prompts --> Inbound : system_prompt

Inbound -> Prompts : build_reply_user_prompt(...)
Prompts --> Inbound : user_prompt

Inbound -> Funnel : get_max_length_for_stage(script, stage)
Funnel --> Inbound : max_length

Inbound -> LLM : generate_response_with_guardrails(messages, last_outbound)
activate LLM
LLM -> MTProto : /chat/completions (OpenRouter or DashScope)
MTProto --> LLM : completion
LLM -> LLM : evaluate guardrails
LLM --> Inbound : response {text, model, tokens_used}

deactivate LLM

alt response empty or fallback
    Inbound -> Inbound : apply fallback text
end

Inbound -> Humanizer : split_message_into_chunks(text)
Humanizer --> Inbound : chunks

Inbound -> Humanizer : calculate_typing_delay(text)
Humanizer --> Inbound : typing_delay_ms

Inbound -> Humanizer : calculate_thinking_delay()
Humanizer --> Inbound : thinking_delay_ms

Inbound -> SellerClient : send_message(chunk, typing_delay_ms)
SellerClient -> MTProto : send reply
MTProto -> Lead : receive reply

Inbound -> ConvSvc : add_message(outbound, response_text, intent, tokens)
activate ConvSvc
ConvSvc -> DB : insert outbound Message
ConvSvc -> Redis : invalidate cache
ConvSvc --> Inbound : Message

deactivate ConvSvc

Inbound -> StateMachine : transition(current_state, event_from_intent)
StateMachine --> Inbound : new_state

Inbound -> DB : update Conversation.state, sentiment, facts

alt intent == meeting_intent or new_state is hot/meeting_booked
    Inbound -> Notif : send_hot_lead_alert(contact, conversation)
    activate Notif
    Notif -> AdminBot : send_message
    AdminBot -> BotAPI : hot lead alert
    BotAPI -> AdminBot : OK
    AdminBot --> Notif : OK
    Notif --> Inbound : OK
    deactivate Notif
end

deactivate Inbound

@enduml
