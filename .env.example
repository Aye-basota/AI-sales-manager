# For Docker Compose use the service names below.
# If you run the project locally without Docker, change postgres -> localhost and redis -> localhost.
DATABASE_URL=postgresql+asyncpg://sales:salespass@postgres:5432/ai_sales
REDIS_URL=redis://redis:6379/0

# LLM provider: "dashscope" or "openrouter"
LLM_PROVIDER=dashscope

# OpenRouter settings (default provider)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# DashScope (Alibaba Cloud) settings
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

ADMIN_BOT_TOKEN=your_telegram_bot_token
ADMIN_NOTIFICATION_CHAT_ID=your_telegram_chat_id
SECRET_KEY=changeme
SESSION_ENCRYPTION_KEY=your_fernet_key_base64
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TGSTAT_TOKEN=
TGSTAT_BASE_URL=https://api.tgstat.ru
SELLER_PHONE=+79991234567
DAILY_MESSAGE_LIMIT=50
DEBUG=True
